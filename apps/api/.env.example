# ─────────────────────────────────────────────
#  Server
# ─────────────────────────────────────────────
PORT=5000
NODE_ENV=development

# ─────────────────────────────────────────────
#  PostgreSQL Database
# ─────────────────────────────────────────────
DB_HOST=localhost
DB_PORT=5432
DB_NAME=bijouq_survey
DB_USER=postgres
DB_PASSWORD=your_password_here

# Full connection string (alternative to individual vars above)
# DATABASE_URL=postgresql://postgres:your_password_here@localhost:5432/bijouq_survey

# ─────────────────────────────────────────────
#  JWT
# ─────────────────────────────────────────────
JWT_SECRET=replace_with_a_long_random_secret_string_min_32_chars
JWT_EXPIRES_IN=8h

# ─────────────────────────────────────────────
#  Admin Credentials (used for first-time seed)
# ─────────────────────────────────────────────
ADMIN_EMAIL=admin@bijouq.com
ADMIN_PASSWORD=Admin@1234

# ─────────────────────────────────────────────
#  CORS — comma-separated list of allowed origins
# ─────────────────────────────────────────────
ALLOWED_ORIGINS=http://localhost:5173,http://localhost:3000